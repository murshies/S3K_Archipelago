{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/murshies/S3K_Archipelago/apworld/user-config.schema.json",
    "title": "Schema for Sonic 3 & Knuckles Archipelago user configuration files",
    "type": "object",
    "properties": {
        "name": {
            "type": "string",
            "description": "The user's name for the game. This must match the filename."
        },
        "game": {
            "type": "string",
            "description": "The name of the game. Must be 'Sonic 3 & Knuckles' for this game.",
            "enum": ["Sonic 3 & Knuckles"]
        },
        "description": {
            "type": "string",
            "description": "Description of this configuration",
            "default": "Sonic 3 & Knuckles Archipelago user configuration"
        },
        "Sonic 3 & Knuckles": {"$ref": "#/definitions/game_config"}
    },
    "required": ["name", "game", "Sonic 3 & Knuckles"],
    "definitions": {
        "game_config": {
            "type": "object",
            "description": "Game settings",
            "additionalProperties": false,
            "properties": {
                "goal": {"$ref": "#/definitions/goal"},
                "death_link": {
                    "type": "boolean",
                    "default": false
                },
                "logic_difficulty": {
                    "type": "string",
                    "description": "The logic difficulty",
                    "default": "standard",
                    "enum": [
                        "standard",
                        "hard"
                    ]
                },
                "zone_unlocks": {
                    "type": "string",
                    "description": "Determines if/how zones and characters are unlocked.",
                    "default": "all_unlocked",
                    "enum": [
                        "all_unlocked",
                        "zones_and_characters",
                        "zones_only",
                        "characters_only"
                    ]
                },
                "enabled_locations": {"$ref": "#/definitions/enabled_locations"}
            },
            "required": ["goal"]
        },
        "goal": {
            "type": "object",
            "description": "Goal definition",
            "additionalProperties": false,
            "properties": {
                "big_rings": {"$ref": "#/definitions/big_ring_goal"},
                "chaos_emeralds": {"$ref": "#/definitions/goal_target"},
                "super_emeralds": {"$ref": "#/definitions/goal_target"}
            },
            "anyOf": [
                {"required": ["big_rings"]},
                {"required": ["chaos_emeralds"]},
                {"required": ["super_emeralds"]}
            ]
        },
        "big_ring_goal": {
            "type": ["object", "null"],
            "description": "Definition for big ring goal",
            "additionalProperties": false,
            "default": null,
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "description": "Whether or not this goal is enabled. Not specifying this goal at all also disables it.",
                    "default": true
                },
                "locations_to_complete": {
                    "type": "integer",
                    "description": "The number of big ring locations to complete this goal",
                    "minimum": 1,
                    "maximum": 77
                },
                "target": {"$ref": "#/definitions/goal_target"}
            },
            "required": ["locations_to_complete", "target"]
        },
        "goal_target": {
            "type": ["string", "null"],
            "description": "The sub goal for the location type. For example, setting 'chaos_emeralds' to 'doomsday' means that getting all seven chaos emeralds unlocks. Not specifying this goal at all disables it.",
            "additionalProperties": false,
            "default": null,
            "enum": [
                "doomsday",
                "knuckles_sky_sanctuary",
                "death_egg"
            ]
        },
        "enabled_locations": {
            "type": "object",
            "description": "The list of locations which are enabled/disabled",
            "additionalProperties": false,
            "properties": {
                "bosses": {
                    "type": "boolean",
                    "default": false,
                    "description": "Toggle minibosses and bosses as a location"
                },
                "big_rings": {
                    "type": "boolean",
                    "default": false,
                    "description": "Toggle big rings as a location"
                },
                "special_stage_emeralds": {
                    "type": "boolean",
                    "default": false,
                    "description": "Toggle special stage emeralds (completion of stage) as a location"
                },
                "special_stage_perfects": {
                    "type": "boolean",
                    "default": false,
                    "description": "Toggle getting a perfect in each special stage as a location"
                },
                "lightning_shields": {
                    "type": "boolean",
                    "default": false,
                    "description": "Toggle lightning shield item boxes as a location"
                },
                "flame_shields": {
                    "type": "boolean",
                    "default": false,
                    "description": "Toggle flame shield item boxes as a location"
                },
                "water_shields": {
                    "type": "boolean",
                    "default": false,
                    "description": "Toggle water shield item boxes as a location"
                },
                "power_sneakers": {
                    "type": "boolean",
                    "default": false,
                    "description": "Toggle power sneaker item boxes as a location"
                },
                "1_ups": {
                    "type": "boolean",
                    "default": false,
                    "description": "Toggle 1 up item boxes as a location"
                },
                "super_rings": {
                    "type": "boolean",
                    "default": false,
                    "description": "Toggle super ring item boxes (10 rings) as a location"
                },
                "robotnik_item_boxes": {
                    "type": "boolean",
                    "default": false,
                    "description": "Toggle robotnik item boxes as a location"
                }
            }
        }
    }
}
